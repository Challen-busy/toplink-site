# ---------- Database ----------
# Neon Postgres connection string. Use the POOLED connection (contains "-pooler")
# for app runtime on Vercel. Get this from https://console.neon.tech → Project → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ---------- Admin auth ----------
# Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-32-byte-hex-string"
# First admin (created / upserted by prisma/seed.ts)
ADMIN_EMAIL="admin@toplinkelec.com"
ADMIN_PASSWORD="changeme-strong-password"

# ---------- Resend email ----------
# Leave blank to skip emails in dev (inquiries still saved to DB)
RESEND_API_KEY=""
INQUIRY_NOTIFY_FROM="TopLink Site <no-reply@toplinkelec.com>"
INQUIRY_NOTIFY_TO="ken@toplinkelec.com,sales@toplinkelec.com"

# ---------- Site ----------
# On Vercel set this to your production URL (e.g. https://toplink-site.vercel.app or your custom domain)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
