generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------
// Product taxonomy: two-level tree (L1 main, L2 sub)
// -----------------------------------------------------------
model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  nameEn      String
  tagline     String? // short one-line positioning
  description String? // longer marketing copy for the category page
  level       Int // 1 or 2
  parentId    String?
  parent      Category?  @relation("Tree", fields: [parentId], references: [id])
  children    Category[] @relation("Tree")
  icon        String? // lucide icon name, e.g. "cable"
  sortOrder   Int        @default(0)
  seoTitle    String?
  seoDesc     String?
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id           String    @id @default(cuid())
  slug         String    @unique
  nameEn       String
  categoryId   String // must be L2 category
  category     Category  @relation(fields: [categoryId], references: [id])
  summary      String // one-sentence hook for cards
  description  String // long-form markdown
  specs        String // JSON string: [{label, value}]
  features     String // JSON string: string[]
  applications String // JSON string: string[]
  images       String // JSON string: string[]
  isHot        Boolean   @default(false)
  published    Boolean   @default(true)
  sortOrder    Int       @default(0)
  seoTitle     String?
  seoDesc      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  inquiries    Inquiry[]
}

// -----------------------------------------------------------
// Inquiries (leads) — unified inbox for all site forms
// -----------------------------------------------------------
model Inquiry {
  id         String        @id @default(cuid())
  source     String // 'product' | 'contact' | 'home-cta' | 'rfq'
  productId  String?
  product    Product?      @relation(fields: [productId], references: [id])
  name       String
  company    String?
  email      String
  phone      String?
  country    String?
  quantity   String?
  message    String
  status     InquiryStatus @default(NEW)
  note       String? // internal admin note
  ipHash     String?
  userAgent  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([productId])
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CLOSED
  SPAM
}

// -----------------------------------------------------------
// Admin users
// -----------------------------------------------------------
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -----------------------------------------------------------
// Site-wide editable content (single row, key = "default")
// -----------------------------------------------------------
model SiteSettings {
  id            String   @id @default("default")
  companyName   String   @default("TopLink Electronics")
  tagline       String   @default("Custom cable and wire harness manufacturing, built to your spec.")
  phone         String   @default("+86-769-85648091")
  phone2        String   @default("+86-769-85648093")
  email1        String   @default("ken@toplinkelec.com")
  email2        String   @default("sales@toplinkelec.com")
  address       String   @default("5F-07 Dexing Science & Technology Park, No.1 Xing'er Road, Wusha, Chang'an Town, Dongguan, Guangdong, China")

  // Home page: service hotline strip (3 slots)
  hotline1Title String   @default("24-Hour Response")
  hotline1Body  String   @default("Our program managers reply to every RFQ within one business day.")
  hotline2Title String   @default("IPC/WHMA-A-620 Certified")
  hotline2Body  String   @default("Every build is inspected to IPC acceptance criteria for cable and wire harness assemblies.")
  hotline3Title String   @default("20+ Years OEM Experience")
  hotline3Body  String   @default("Trusted by automotive, medical, industrial, and telecom customers across 30+ countries.")

  // Home page: hero content
  heroEyebrow   String   @default("Contract manufacturer · Dongguan, China")
  heroTitle     String   @default("Interconnect solutions, crafted with care.")
  heroSubtitle  String   @default("From signal to power, from prototype to mass production — we build the cable and harness assemblies your product needs.")

  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------
// Live chat sessions & messages
// -----------------------------------------------------------
model ChatSession {
  id        String        @id @default(cuid())
  status    ChatStatus    @default(AI)
  language  String? // detected visitor language, e.g. "en", "zh"
  visitorIp String?
  userAgent String?
  pageUrl   String? // page visitor was on when they started the chat
  summary   String? // AI-generated one-liner for admin list
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([status, updatedAt])
}

enum ChatStatus {
  AI
  HANDOFF
  HUMAN
  CLOSED
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "visitor" | "ai" | "human" | "system"
  content   String
  toolCall  String? // JSON: serialized function call for audit
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
}

// -----------------------------------------------------------
// Success cases (editable in admin, shown on home)
// -----------------------------------------------------------
model SuccessCase {
  id          String   @id @default(cuid())
  industry    String // e.g. "Automotive ADAS"
  customer    String // e.g. "Tier-1 supplier"
  title       String // e.g. "360° camera harness program"
  story       String // 2-3 sentences
  metric      String? // e.g. "500k+ units/year"
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
